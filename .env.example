# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://kc_user:kc_secret@localhost:5432/kiddie_chic"

# ── Next.js / Auth.js v5 ───────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET=""          # openssl rand -base64 32

# Admin credentials (seeded via: npm run db:seed)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""       # plain text — hashed with bcrypt during seed

# ── Cloudinary ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Resend ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="orders@yourdomain.ua"

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""   # numeric chat ID of the owner

# ── Monobank Acquiring ─────────────────────────────────────────────────────────
MONOBANK_TOKEN=""
MONOBANK_WEBHOOK_SECRET=""  # for X-Sign signature verification

# ── Nova Poshta ────────────────────────────────────────────────────────────────
NOVA_POSHTA_API_KEY=""

# ── Google Analytics ───────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=""        # G-XXXXXXXXXX

# ── App URL (sitemap, OG images, email links) ──────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
